	}
	$form['all'] = array(
		'#type' => 'fieldset',
		'#title' => t('Delete All Readings'),
		'#collapsible' => TRUE,
		'#collapsed' => FALSE,
	);
	$form['all']['delete_all'] = array(
		'#type' => 'checkbox',
		'#title' => t('Delete All Readings in the database.'),
		'#default_value' => '0',
		'#required' => FALSE,
	);
	$form['database'] = array(
		'#type' => 'fieldset',
		'#title' => t('Database'),
		'#collapsible' => TRUE,
		'#collapsed' => FALSE,
	);
	$form['database']['yesnocron'] = array(
		'#type' => 'checkbox',
		'#title' => t('Delete readings after 1 hour. (default)'),
		'#default_value' => variable_get('yesnocron', 1),
		'#required' => FALSE,

	);
	$form['database']['selected'] = array(
		'#type' => 'select',
		'#title' => t('The length of time to store readings.'),
		'#options' => array(
			'1' => t('1 day'),
			'7' => t('1 week'),
			'30' => t('1 month'),
			'90' => t('3 months'),
			'180' => t('6 months'),
			'270' => t('9 months'),
			'365' => t('1 year'),
			'forever' => t('forever'),
	),
	'#default_value' => variable_get('selected', 'options'),
	'#description' => t('Set this to change the default storage setting.'),
 	'#states' => array(
    		'visible' => array(
      			':input[name="yesnocron"]' => array('checked' => FALSE),
			),
