/**
 * Implements hook_menu().
 *
 */
function tao_iching_menu() {

	$items = array();

	$items['i-ching'] = array(
		'title' => 'I-Ching, the Book of Changes',
		'description' => 'Cast your I-Ching, and read an interpretation.',
		'page callback' => 'drupal_get_form',
		'page arguments' => array('tao_iching_form'),
		'access callback' => TRUE,
	);

	$items['result'] = array(
		'title' => 'I-Ching, the Book of Changes',
		'description' => 'Cast your I-Ching, and read an interpretation.',
		'page callback' => 'tao_iching_view',
		'access arguments' => array('access content')
	);

	return $items;

}


/**
 * Implements hook_theme_registry_alter().
 *
 * makes the theme registry aware of our module template(s)
 */
function tao_iching_theme_registry_alter(&$theme_registry) {
	// Defined path to the current module.
	$module_path = drupal_get_path('module', 'tao_iching');
	// Find all .tpl.php files in this module's folder recursively.
	$template_file_objects = drupal_find_theme_templates($theme_registry, '.tpl.php', $module_path);
	// Iterate through all found template file objects.
	foreach ($template_file_objects as $key => $template_file_object) {
		// If the template has not already been overridden by a theme.
		if (!isset($theme_registry[$key]['theme path']) || !preg_match('#/themes/#', $theme_registry[$key]['theme path'])) {
			// Alter the theme path and template elements.
			$theme_registry[$key]['theme path'] = $module_path;
			$theme_registry[$key] = array_merge($theme_registry[$key], $template_file_object);
			$theme_registry[$key]['type'] = 'module';
		}
	}
}


/**
 * Implements hook_form_alter().
 *
 * only theme the module form
 */
function tao_iching_form_alter(&$form, &$form_state, $form_id) {

  	if ($form_id == 'tao_iching_form') {
    		$form['#theme'] = array('tao_iching_form');
  	}
}


/**
 * Implements hook_theme().
 *
 * a form template for the i-ching page
 */
function tao_iching_theme($existing, $type, $theme, $path) {
	$items['tao_iching_form'] = array(
  		'render element' => 'form',
    		'template' => 'tao_iching-form',
    		'path' => '/templates',
  	);

  	return $items;
}


/**
 * Implements hook_preprocess_page().
 *
 * display the correct title
 */
function tao_iching_preprocess_page(&$vars){
	$currentpath = current_path();
	if (($currentpath == "i-ching") || ($currentpath == "result")) {
		drupal_set_title('I-Ching, the Book of Changes');
 	}
}


