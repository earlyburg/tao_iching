/**
 * Implements hook_menu().
 */
function tao_iching_menu() {

	$items = array();
	$items['i-ching'] = array(
		'title' => 'I-Ching, the Book of Changes',
		'description' => 'Cast your I-Ching, and read an interpretation.',
		'page callback' => 'drupal_get_form',
		'page arguments' => array('tao_iching_form'),
		'access callback' => TRUE,
	);
	$items['result/%'] = array(
		'title' => 'I-Ching, the Book of Changes',
		'page arguments' => array(1),
		'description' => 'Cast your I-Ching, and read an interpretation.',
		'page callback' => 'tao_iching_view',
		'access arguments' => array('access content')
	);
	$items['statistics'] = array(
		'title' => 'I-Ching, the Book of Changes',
		'description' => 'I-Ching Statistics',
		'page callback' => 'tao_iching_stats',
		'access arguments' => array('access content')
	);
	$items['admin/config/user-interface/tao_iching'] = array(
		'title' => 'Tao I-Ching',
		'description' => 'Tao I-Ching Settings.',
		'page callback' => 'drupal_get_form',
    		'page arguments' => array(
			'tao_iching_admin'
		),
		'access arguments' => array('access administration pages'),
		'file' => 'system.admin.inc',
		'file path' => drupal_get_path('module', 'system'),
		'type' => MENU_NORMAL_ITEM,
	);
	return $items;
}


/**
 * Implements hook_cron()
 */
function tao_iching_cron() {

	if ( tao_iching_crn_tm() ) {

		$I_Ching = new I_Ching();

		$idArray = db_query('SELECT id, timestamp FROM {tao_iching_readings}')->fetchAll();

		foreach ($idArray as $key => $value) {

			if ( $I_Ching->checkTimestamp($value->timestamp) ) {

				$I_Ching->deleteReading($value->id);
			}
		}
	}
	tao_iching_crn_cln_db();
}


/**
 * Implements hook_theme_registry_alter().
 * makes the theme registry aware of our module template(s)
 */
function tao_iching_theme_registry_alter(&$theme_registry) {

	/* Defined path to the current module. */
	$module_path = drupal_get_path('module', 'tao_iching');

	/* Find all .tpl.php files in this module's folder recursively. */
	$template_file_objects = drupal_find_theme_templates($theme_registry, '.tpl.php', $module_path);

	/* Iterate through all found template file objects. */
	foreach ($template_file_objects as $key => $template_file_object) {

		/* If the template has not already been overridden by a theme. */
		if (!isset($theme_registry[$key]['theme path']) || !preg_match('#/themes/#', $theme_registry[$key]['theme path'])) {

			/* Alter the theme path and template elements. */
			$theme_registry[$key]['theme path'] = $module_path;
			$theme_registry[$key] = array_merge($theme_registry[$key], $template_file_object);
			$theme_registry[$key]['type'] = 'module';
		}
	}
}


/**
 * Implements hook_form_alter().
 */
function tao_iching_form_alter(&$form, &$form_state, $form_id) {

  	if ($form_id == 'tao_iching_form') {

   		$form['#theme'] = array('tao_iching_form');
  	}
}


/**
 * Implements hook_theme().
 * a form template for the i-ching page
 */
function tao_iching_theme($existing, $type, $theme, $path) {

	$items['tao_iching_form'] = array(
  		'render element' => 'form',
    		'template' => 'tao_iching-form',
    		'path' => '/templates',
  	);
  	return $items;
}


/**
 * Implements hook_preprocess_page().
 * display the correct title
 */
function tao_iching_preprocess_page(&$vars) {

	$currentpath = current_path();
	if (($currentpath == "i-ching") || ($currentpath == "result")) {

		drupal_set_title('I-Ching, the Book of Changes');
 	}
}


/**
 * Add CSS
 */
drupal_add_css(drupal_get_path('module', 'tao_iching') . '/css/tao_iching.css', array('group' => CSS_DEFAULT, 'every_page' => FALSE));

/**
 * Add Javascript
 */
drupal_add_js(drupal_get_path('module', 'tao_iching') . '/js/tao_iching.js');
drupal_add_js(drupal_get_path('module', 'tao_iching') . '/lib/plotly.js');


/**
 * tao_iching_submit_callback()
 */
function tao_iching_submit_callback($form, $form_state) {

	global $user;
	$I_Ching = new I_Ching();
	$id = array();

	/* set a session id */	
	if ( empty($_SESSION['TaoTeChingID']) || !isset($_SESSION['TaoTeChingID']) ) {

		$id = $I_Ching->makeID();
		$_SESSION['TaoTeChingID'] = $id['id'];
	} 

	/* generate hexagram line */
	$user_click = $I_Ching->line();

	/* get & set the values from the toss */
	foreach ($user_click as $key => $value) {

		if ($key != "line" && $key != "coinsval") {

			$keyBucket = $key;
			$valBucket = $value;
		}
	}
	$sessionId = $_SESSION['TaoTeChingID'];
	$line = $user_click['line'];
	$tri_name = $keyBucket;
	$code = $valBucket;
	$coinsval = $user_click['coinsval'];

	/* start a reading database session */
	if ( $I_Ching->readingExist($sessionId) ) {

		$throw_num = $I_Ching->checkNumber($sessionId) + 1;
		$return2 = $I_Ching->insertLine($sessionId, $throw_num, $line, $tri_name, $code, $coinsval);
	} else {

		$throw_num = "1";
		$I_Ching->readingInit($id, $form['question']['#value']);
		$return1 = $I_Ching->insertLine($sessionId, $throw_num, $line, $tri_name, $code, $coinsval);
	}

	$localChing = $I_Ching->myIching($sessionId);

	/* markup form element */	
	$element = $form['iching_box'];

	ctools_include('ajax');
	ctools_add_js('ajax-responder');
	$commands[] = ctools_ajax_command_redirect('result/' . $sessionId);

	/* once we have cast the coins 6 times... */
	if ( $I_Ching->checkNumber($sessionId) == 6 ) {

		/* log the user's question */
		$type = "Tao I-Ching";

		if ( $user->uid ) {
			$message = $user->name . " asked the I-Ching: " . $form['question']['#value'];
		} else {
			$message = "An anonymous visitor asked the I-Ching: " . $form['question']['#value'];
		}

		watchdog($type, $message, $variables = array(), $severity = WATCHDOG_NOTICE, $link = NULL);
		$_SESSION['TaoTeChingID'] = NULL;
		print ajax_render($commands);
		exit;
	}
	/* create the coins display */
	$s = count( $localChing['initial'] );

	/* safeguard against broken sessions */
	if ( intval($s) >= 7 ) {

		/* delete the reading */
		$I_Ching->deleteReading($id);
		drupal_set_message("Apologies, there was a problem with the website. Please try again.");
		/* clear the session */
		$_SESSION['TaoTeChingID'] = NULL;
	} 
	$element['#markup'] = "<div id='coin'>";
	switch ($coinsval) {
		case 9:
			$element['#markup'] .= "<img src='/sites/all/modules/tao_iching/imgs/heads.png'>";
			$element['#markup'] .= "<img src='/sites/all/modules/tao_iching/imgs/heads.png'>";
			$element['#markup'] .= "<img src='/sites/all/modules/tao_iching/imgs/heads.png'>";
		       	break;
		case 8:
			$element['#markup'] .= "<img src='/sites/all/modules/tao_iching/imgs/heads.png'>";
			$element['#markup'] .= "<img src='/sites/all/modules/tao_iching/imgs/heads.png'>";
			$element['#markup'] .= "<img src='/sites/all/modules/tao_iching/imgs/tails.png'>";
		        break;
		case 7:
			$element['#markup'] .= "<img src='/sites/all/modules/tao_iching/imgs/heads.png'>";
			$element['#markup'] .= "<img src='/sites/all/modules/tao_iching/imgs/tails.png'>";
			$element['#markup'] .= "<img src='/sites/all/modules/tao_iching/imgs/tails.png'>";
		       	break;
		case 6;
			$element['#markup'] .= "<img src='/sites/all/modules/tao_iching/imgs/tails.png'>";
			$element['#markup'] .= "<img src='/sites/all/modules/tao_iching/imgs/tails.png'>";
			$element['#markup'] .= "<img src='/sites/all/modules/tao_iching/imgs/tails.png'>";
			break;
		case 0;
			$element['#markup'] .= "<img src='/sites/all/modules/tao_iching/imgs/heads.png'>";
		 	$element['#markup'] .= "<img src='/sites/all/modules/tao_iching/imgs/heads.png'>";
		 	$element['#markup'] .= "<img src='/sites/all/modules/tao_iching/imgs/heads.png'>";
			break;
		default:
			$element['#markup'] .= "<img src='/sites/all/modules/tao_iching/imgs/heads.png'>";
		 	$element['#markup'] .= "<img src='/sites/all/modules/tao_iching/imgs/heads.png'>";
		 	$element['#markup'] .= "<img src='/sites/all/modules/tao_iching/imgs/heads.png'>";
	}
	$element['#markup'] .= "</div>"; /* #coin */
	/* fix our output to be readable */
	$raw = $line;

	switch ($raw) {
		case "yang_changing":
			$legible = str_replace("yang_changing", "Yang, changing.", $raw);
			break;
		case "yin":
			$legible = str_replace("yin", "Yin.", $raw);
			break;
		case "yin_changing":
			$legible = str_replace("yin_changing", "Yin, changing.", $raw);
			break;
		case "yang":
			$legible = str_replace("yang", "Yang.", $raw);
			break;
	}

	$element['#markup'] .= "<div id='iching_form_blurb'>";
	$element['#markup'] .= "Coin toss " . $s . " yields " . $legible;
	$element['#markup'] .= "</div>"; /* #iching_form_blurb */
	$element['#markup'] .= "<div class='sm_line'>";
	$element['#markup'] .= "<img src='/sites/all/modules/tao_iching/imgs/" . $line . "_sm.png'>";
	$element['#markup'] .= "</div>"; /* .sm_line */

	return $element;
}


/**
 * Implements hook_form().
 */
function tao_iching_form($form, &$form_state) {

	$form['question'] = array(
   		'#type' => 'textarea',
   		'#title' => 'Ask A Question.',
   		'#cols' => 10,
   		'#resizable' => FALSE,
   		'#rows' => 1,
   	);

  	$form['iching_box'] = array(
   	 	'#type' => 'markup',
    		'#prefix' => '<div id="iching_box">',
    		'#suffix' => '</div>',
    		'#markup' => "<div id='coin'><img src='/sites/all/modules/tao_iching/imgs/heads.png'><img src='/sites/all/modules/tao_iching/imgs/heads.png'><img src='/sites/all/modules/tao_iching/imgs/heads.png'></div><div id='iching_form_blurb'></div><div class='sm_line'></div>",
  	);

  	$form['submit_button'] = array(
    		'#type' => 'submit',
    		'#ajax' => array(
      			'callback' => 'tao_iching_submit_callback',
      			'wrapper' => 'iching_box',
    		),
    		'#value' => t('Toss The Coins'),
		'#attributes' => array(
			'class' => array(
				'i-ching-submit'
			),
			'name' => array(
				'i-ching-toss',
			),
		),
  	);

  	return $form;
}


/**
 * Implements hook_view().
 */
function tao_iching_view($callbackResult) {

	$I_Ching = new I_Ching();
	if ($I_Ching->readingExist($callbackResult)) { ##- 6 CLICKS METHOD -##

		/* retreive the first hexagram */
		$localChing = $I_Ching->myIching($callbackResult);

		/* generate the final reading */
		$finalChing = $I_Ching->complete($localChing['initial']);
		$finalchg = $finalChing['changed'];

		/* flip the arrays because traditionally I-Ching is read bottom to top */
		$flippedInitial = array_reverse($finalChing['initial']);
		if($finalchg != "No Change") {
			$flippedChanged = array_reverse($finalChing['changed']);
		}

		$content = "<div class='iching_content'>";
	   	$content .= "<div class='sm_hexag'>";

	     	foreach ($flippedInitial as $key => $value) {

	     		$content .=  "<div class='min_line'>";
	     		$content .=  "<img src='/sites/all/modules/tao_iching/imgs/" . $value['line'] . "_min.png'>";
	     		$content .=  "</div>";
	    	}
	   	$content .= "</div>";
	   	$content .= "<div class='sm_hexag'>";

	     	if ($finalChing['changed'] == "No Change") {

		     	foreach ($flippedInitial as $key => $value) {

		     		$content .=  "<div class='min_line'>";
		     		$content .=  "<img src='/sites/all/modules/tao_iching/imgs/" . $value['line'] . "_min.png'>";
		     		$content .=  "</div>";
		    	}
	     	} else {

	      		foreach ($flippedChanged as $key => $value) {

	       			$content .=  "<div class='min_line'>";
	       			$content .=  "<img src='/sites/all/modules/tao_iching/imgs/" . $value['line'] . "_min.png'>";
	       			$content .=  "</div>";
	      		}
	     	}
	   	$content .= "</div>";

	  	$content .= "<div class='iching_blurb'>";
	  	$content .= "<a href='/i-ching'><b>Click Here to start again.</b></a>";
	  	$content .= "</div>";
	  	$content .= "</div>";

	 	$content .= "<div class='iching_container'>";

		/* get rid of the change indicators and display the final hexagram(s) */
		$finalhex = $I_Ching->rawhex_cleanup($flippedInitial);

		/* get the book numbers for the hexagram(s) */
		$bookname = $I_Ching->findBooknum($finalhex);

		/* get the book from the first hexagram */
		$origBook = $I_Ching->findBook($finalhex);

	  	if($finalchg != "No Change") {

	   		$ch_bookname = $I_Ching->findBooknum($flippedChanged);
			/* get the second book if there is one */
			$chBook = $I_Ching->findBook($flippedChanged);
	  	}
		/* print the question */
		if ($finalChing['question'] != NULL) {
	     		$content .= "<div class='iching_blurb'>";
	       		$content .= "<b>";
	       		$content .= $finalChing['question'];
	       		$content .= "</b>";
	       		$content .= "</div>";
	     	}
	     	$content .= "<div class='iching_blurb'>";
	     	$content .= "<br>";
	     	$content .= "</div>";

	  	$content .= "<div class='iching_tab'>";
		/* html to make our javascript work */
	  	$content .= file_get_contents(drupal_get_path('module', 'tao_iching') . "/includes/result_html.php");
	  	$content .= "</div>";

	  	$content .= "<div id='Current' class='iching_tabcontent'>";
	  	$content .= "<h3>Current</h3>"; /* CURRENT */

	     	$content .= "<div class='hexag'>";
	      	foreach ($finalhex as $name) {
	       		$content .= "<div class='sm_line'>";
	       		$content .= "<img src='/sites/all/modules/tao_iching/imgs/" . $name['line'] . "_sm.png'>";
	       		$content .= "</div>";
	      	}
	     	$content .= "</div>";

	   	$content .= "<div class='iching_links'>";

	   	$content .= "<a class='colorbox-inline' href='?width=600&height=500&inline=true#iching_j_text'>The Judgement</a>";
	   	$content .= "<div style='display: none;'>";
	   	$content .= "<div id='iching_j_text'><p>" . $origBook['judge'] . "</p></div>";
	   	$content .= "</div>";

	   	$content .= "<a class='colorbox-inline' href='?width=600&height=500&inline=true#iching_i_text'>The Image</a>";
	   	$content .= "<div style='display: none;'>";
	   	$content .= "<div id='iching_i_text'><p>" . $origBook['image'] . "</p></div>";
	   	$content .= "</div>";

	   	$content .= "</div>";

	   	$content .= $bookname . " - ";
	   	$content .= $origBook['descr'];

	  	$content .= "</div>";

	  	$content .= "<div id='Changing' class='iching_tabcontent'>";
	  	$content .= "<h3>Changing</h3>"; /* CHANGING */

	    	if($finalchg != "No Change") {
	     		$content .= "<div class='hexag'>";

			$book_cng_key = $I_Ching->findTopChanging($flippedInitial);
		 	foreach ($flippedInitial as $name) {
		  		$content .= "<div class='sm_line'>";
		  		$content .= "<img src='/sites/all/modules/tao_iching/imgs/" . $name['line'] . "_sm.png'>";
		  		$content .= "</div>";
		 	}
	     		$content .= "</div>";
	    	} else $content .= "<div>There are no changing lines. The situation is expected to remain the same in the near future.</div>";

	      	if($finalchg != "No Change") {

	       		$content .= $chBook[$book_cng_key];
		}

		$content .= "</div>";

		$content .= "<div id='Transformed' class='iching_tabcontent'>";
	 	$content .= "<h3>Transformed</h3>"; /* TRANSFORMED */

	    	if($finalchg != "No Change") {
	     		$content .= "<div class='hexag'>";
	       		foreach ($flippedChanged as $chgname) {
				$content .= "<div class='sm_line'>";
				$content .= "<img src='/sites/all/modules/tao_iching/imgs/" . $chgname['line'] . "_sm.png'>";
				$content .= "</div>";
	       		}
	      		$content .= "</div>";
	     	} else $content .= "<div>There are no changing lines. The situation is expected to remain the same in the near future.</div>";

	      	if($finalchg != "No Change") {
			$content .= "<div class='iching_links'>";

			$content .= "<a class='colorbox-inline' href='?width=600&height=500&inline=true#iching_j_ch_text'>The Judgement</a>";
			$content .= "<div style='display: none;'>";
			$content .= "<div id='iching_j_ch_text'><p>" . $chBook['judge'] . "</p></div>";
			$content .= "</div>";
			$content .= "<a class='colorbox-inline' href='?width=600&height=500&inline=true#iching_i_ch_text'>The Image</a>";
			$content .= "<div style='display: none;'>";
			$content .= "<div id='iching_i_ch_text'><p>" . $chBook['image'] . "</p></div>";
			$content .= "</div>";

	   		$content .= "</div>";
	    		$content .= $ch_bookname . " - ";
	    		$content .= $chBook['descr'];
	   	}

	  	$content .= "</div>";
	  	$content .= "</div>";

	  	$content .= "<SCRIPT>";
	  	$content .= "document.getElementById('defaultOpen').click();";
	  	$content .= "</SCRIPT>";
		/* clear the session ID */
		$_SESSION['TaoTeChingID'] = NULL; 	

	} else if ($callbackResult == "instant") { ##- INSTANT METHOD -##

		$hexagram = $I_Ching->hexagram();
		$finalChing = $I_Ching->complete($hexagram);

		$finalchg = $finalChing['changed'];

		/* flip the arrays because traditionally I-Ching is read bottom to top */
		$flippedInitial = array_reverse($finalChing['initial']);
		if($finalchg != "No Change") {
			$flippedChanged = array_reverse($finalChing['changed']);
		}

		$content = "<div class='iching_content'>";
	   	$content .= "<div class='sm_hexag'>";
	     	foreach ($flippedInitial as $key => $value) {

	     		$content .=  "<div class='min_line'>";
	     		$content .=  "<img src='/sites/all/modules/tao_iching/imgs/" . $value['line'] . "_min.png'>";
	     		$content .=  "</div>";
	    	}
	   	$content .= "</div>";
	   	$content .= "<div class='sm_hexag'>";
	     	if ($finalChing['changed'] == "No Change") {

		     	foreach ($flippedInitial as $key => $value) {

		     		$content .=  "<div class='min_line'>";
		     		$content .=  "<img src='/sites/all/modules/tao_iching/imgs/" . $value['line'] . "_min.png'>";
		     		$content .=  "</div>";
		    	}
	     	} else {

	      		foreach ($flippedChanged as $key => $value) {

	       			$content .=  "<div class='min_line'>";
	       			$content .=  "<img src='/sites/all/modules/tao_iching/imgs/" . $value['line'] . "_min.png'>";
	       			$content .=  "</div>";
	      		}
	     	}
	   	$content .= "</div>";
	  	$content .= "<div class='iching_blurb'>";
	  	$content .= "<a href='/i-ching'><b>Click Here to start again.</b></a>";
	  	$content .= "</div>";
	  	$content .= "</div>";
	 	$content .= "<div class='iching_container'>";

		/* get rid of the change indicators and display the final hexagram(s) */
		$finalhex = $I_Ching->rawhex_cleanup($flippedInitial);

		/* get the book numbers for the hexagram(s) */
		$bookname = $I_Ching->findBooknum($finalhex);

		/* get the book from the first hexagram */
		$origBook = $I_Ching->findBook($finalhex);

	  	if($finalchg != "No Change") {

	   		$ch_bookname = $I_Ching->findBooknum($flippedChanged);
			/* get the second book if there is one */
			$chBook = $I_Ching->findBook($flippedChanged);
	  	}
		/* print the question */
		if ($finalChing['question'] != NULL) {

	     		$content .= "<div class='iching_blurb'>";
	       		$content .= "<b>";
	       		$content .= $finalChing['question'];
	       		$content .= "</b>";
	       		$content .= "</div>";
	     	}
	     	$content .= "<div class='iching_blurb'>";
	     	$content .= "<br>";
	     	$content .= "</div>";

	  	$content .= "<div class='iching_tab'>";
		/* html to make our javascript work */
	  	$content .= file_get_contents(drupal_get_path('module', 'tao_iching') . "/includes/result_html.php");

	  	$content .= "</div>";

	  	$content .= "<div id='Current' class='iching_tabcontent'>";
	  	$content .= "<h3>Current</h3>"; /* CURRENT */

	     	$content .= "<div class='hexag'>";
	      	foreach ($finalhex as $name) {

	       		$content .= "<div class='sm_line'>";
	       		$content .= "<img src='/sites/all/modules/tao_iching/imgs/" . $name['line'] . "_sm.png'>";
	       		$content .= "</div>";
	      	}
	     	$content .= "</div>";

	   	$content .= "<div class='iching_links'>";

	   	$content .= "<a class='colorbox-inline' href='?width=600&height=500&inline=true#iching_j_text'>The Judgement</a>";
	   	$content .= "<div style='display: none;'>";
	   	$content .= "<div id='iching_j_text'><p>" . $origBook['judge'] . "</p></div>";
	   	$content .= "</div>";

	   	$content .= "<a class='colorbox-inline' href='?width=600&height=500&inline=true#iching_i_text'>The Image</a>";
	   	$content .= "<div style='display: none;'>";
	   	$content .= "<div id='iching_i_text'><p>" . $origBook['image'] . "</p></div>";
	   	$content .= "</div>";

	   	$content .= "</div>";

	   	$content .= $bookname . " - ";
	   	$content .= $origBook['descr'];

	  	$content .= "</div>";

	  	$content .= "<div id='Changing' class='iching_tabcontent'>";
	  	$content .= "<h3>Changing</h3>"; /* CHANGING */

	    	if($finalchg != "No Change") {

	     		$content .= "<div class='hexag'>";
			$book_cng_key = $I_Ching->findTopChanging($flippedInitial);
		 	foreach ($flippedInitial as $name) {

		  		$content .= "<div class='sm_line'>";
		  		$content .= "<img src='/sites/all/modules/tao_iching/imgs/" . $name['line'] . "_sm.png'>";
		  		$content .= "</div>";
		 	}
	     		$content .= "</div>";
	    	} else $content .= "<div>There are no changing lines. The situation is expected to remain the same in the near future.</div>";

	      	if($finalchg != "No Change") {

	       		$content .= $chBook[$book_cng_key];
		}

		$content .= "</div>";

		$content .= "<div id='Transformed' class='iching_tabcontent'>";
	 	$content .= "<h3>Transformed</h3>"; /* TRANSFORMED */

	    	if($finalchg != "No Change") {

	     		$content .= "<div class='hexag'>";
	       		foreach ($flippedChanged as $chgname) {

				$content .= "<div class='sm_line'>";
				$content .= "<img src='/sites/all/modules/tao_iching/imgs/" . $chgname['line'] . "_sm.png'>";
				$content .= "</div>";
	       		}
	      		$content .= "</div>";
	     	} else $content .= "<div>There are no changing lines. The situation is expected to remain the same in the near future.</div>";

	      	if($finalchg != "No Change") {

			$content .= "<div class='iching_links'>";
			$content .= "<a class='colorbox-inline' href='?width=600&height=500&inline=true#iching_j_ch_text'>The Judgement</a>";
			$content .= "<div style='display: none;'>";
			$content .= "<div id='iching_j_ch_text'><p>" . $chBook['judge'] . "</p></div>";
			$content .= "</div>";
			$content .= "<a class='colorbox-inline' href='?width=600&height=500&inline=true#iching_i_ch_text'>The Image</a>";
			$content .= "<div style='display: none;'>";
			$content .= "<div id='iching_i_ch_text'><p>" . $chBook['image'] . "</p></div>";
			$content .= "</div>";
	   		$content .= "</div>";
		}

	   	if($finalchg != "No Change") {

	    		$content .= $ch_bookname . " - ";
	    		$content .= $chBook['descr'];
	   	}

	  	$content .= "</div>";
	  	$content .= "</div>";

	  	$content .= "<SCRIPT>";
	  	$content .= "document.getElementById('defaultOpen').click();";
	  	$content .= "</SCRIPT>";
		/* clear the session ID */
		$_SESSION['TaoTeChingID'] = NULL;

	} else {

		$content = "<div class='iching_blurb'>";
		$content .= "Sorry, that I-Ching reading is not in our database.<br>";
	  	$content .= "<a href='/i-ching'><b>Click Here to start again.</b></a>";
	  	$content .= "</div>";
		/* clear the session ID */
		$_SESSION['TaoTeChingID'] = NULL;
	}
	return $content;
}


/*
 *  /statistics
 */
function tao_iching_stats() {

	$I_Ching = new I_Ching();
	$idArray = db_query('SELECT id FROM {tao_iching_readings}')->fetchAll();
	$rdCount = count($idArray);

	$bookNameArray = array();
	$bookArray = array();

	foreach ($idArray as $key => $value) {
		/* retrieve the first hexagram */
		$localChing = $I_Ching->myIching($value->id);
		/* flip the array because traditionally I-Ching is read bottom to top */
		$flippedInitial = array_reverse($localChing['initial']);
		/* get rid of the change indicators */
		$finalhex = $I_Ching->rawhex_cleanup($flippedInitial);
		/* get the book number for the hexagram */
		$bookname = $I_Ching->findBooknum($finalhex);
		/* get the book from the first hexagram */
		$origBook = $I_Ching->findBook($finalhex);
		$bookArray[] = $origBook;
		$needle = "<br>";
		$bookNameArray[] = strstr($origBook['descr'], $needle, true);
	}
	$sortedNameArray = array_count_values($bookNameArray);
	asort($sortedNameArray);
	$graphNames = array();
	$graphNums = array();
	foreach ($sortedNameArray as $sKey => $sValue) {

		$graphNames[] = $sKey;
		$graphNums[] = $sValue;
	}
	$reversedNames = array_reverse($graphNames);
	$reversedNums = array_reverse($graphNums);
	$finalNames = array_slice($reversedNames, 0, 10);
	$finalNums = array_slice($reversedNums, 0, 10);

	$content = "<script>var valArray = " . json_encode($finalNums, TRUE) . ";</script>";
	$content .= "<script>var labelArray = " . json_encode($finalNames, TRUE) . ";</script>";
	$content .= "<h3>Top 10 Hexagrams</h3>";
	$content .= "There are " . $rdCount . " readings in the database.<br>";
	$content .= "<a href='/i-ching'><b>Cast the I-Ching.</b></a>";
	$content .= '<div id="piechart"></div>';

	return $content;
}


/*
 * Implements hook_admin().
 */
function tao_iching_admin() {

	global $user;
	$idArray = db_query('SELECT id, timestamp FROM {tao_iching_readings}')->fetchAll();
  	$form = array();
	$readCount = count($idArray);
	$form['readings'] = array(
		'#type' => 'fieldset',
		'#title' => t($readCount . ' Readings'),
		'#description' => t('Delete individual readings.'),
		'#collapsible' => TRUE,
		'#collapsed' => TRUE,
	);
	foreach ($idArray as $key => $value) {

		$convertedtime = date('d/m/Y h:i:s', $value->timestamp);

	  	$form['readings']["'" . $value->timestamp . "'"] = array(
	    		'#type' => 'checkbox',
	    		'#title' => t("&nbsp;&nbsp;<a href='/result/" . $value->id . "' target='_new'>" . $user->name . " at " . $convertedtime) . "</a>",
