/**
 * Implements hook_menu().
 */
function tao_iching_menu() {

  $items = array();

  $items['i-ching'] = array(
    'title' => 'I-Ching, the Book of Changes',
    'description' => 'Cast your I-Ching, and read an interpretation.',
    'page callback' => 'drupal_get_form',
    'page arguments' => array('tao_iching_form'),
    'access callback' => TRUE,
  );

  $items['result'] = array(
    'title' => 'I-Ching, the Book of Changes',
    'description' => 'Cast your I-Ching, and read an interpretation.',
    'page callback' => 'tao_iching_view',
    'access arguments' => array('access content')
  );

  return $items;

} // end tao_iching_menu()



/**
 * Implements hook_theme_registry_alter().
 */
// makes the theme registry aware of our module template(s)
function tao_iching_theme_registry_alter(&$theme_registry) {
// Defined path to the current module.
  $module_path = drupal_get_path('module', 'tao_iching');
// Find all .tpl.php files in this module's folder recursively.
  $template_file_objects = drupal_find_theme_templates($theme_registry, '.tpl.php', $module_path);
// Iterate through all found template file objects.
  foreach ($template_file_objects as $key => $template_file_object) {
// If the template has not already been overridden by a theme.
    if (!isset($theme_registry[$key]['theme path']) || !preg_match('#/themes/#', $theme_registry[$key]['theme path'])) {
// Alter the theme path and template elements.
      $theme_registry[$key]['theme path'] = $module_path;
      $theme_registry[$key] = array_merge($theme_registry[$key], $template_file_object);
      $theme_registry[$key]['type'] = 'module';
    }
  }
}

// custom css for the basic layout
   drupal_add_css(drupal_get_path('module', 'tao_iching') . '/css/tao_iching.css', array('group' => CSS_DEFAULT, 'every_page' => FALSE));

// javascript for the result page
   drupal_add_js(drupal_get_path('module', 'tao_iching') . '/js/tao_iching.js');

/**
 * Implements hook_form().
 */
// make the form
function tao_iching_form($form, &$form_state) {

  $form['question'] = array(
   '#type' => 'textarea',
   '#title' => 'Ask A Question.',
   '#cols' => 35,
   '#resizable' => TRUE,
   '#rows' => 2,
   );
  $form['submit_button'] = array(
    '#type' => 'submit',
    '#attributes' => array(
    'class' => array(
      'custom_mod_submit'
     ),
   ),
    '#value' => t('Toss The Coins'),
  );

  return $form;

} // end of tao_iching_form()



/**
 * Implements hook_form_alter().
 */
// only theme the module form
function tao_iching_form_alter(&$form, &$form_state, $form_id) {
  if ($form_id == 'tao_iching_form') {
    $form['#theme'] = array('tao_iching_form');
  }
}

/**
 * Implements hook_theme().
 */
/** a form template for the i-ching page */
function tao_iching_theme($existing, $type, $theme, $path) {

    $items['tao_iching_form'] = array(
        'render element' => 'form',
        'template' => 'tao-iching-form',
        'path' => '/templates',
    );

    return $items;
}

/**
 * Implements hook_preprocess_page().
 */
// display the correct title
function tao_iching_preprocess_page(&$vars){

$currentpath = current_path();
 if (($currentpath == "i-ching") || ($currentpath == "result")) {
   drupal_set_title('I-Ching, the Book of Changes');
 }
}


/**
 * Implements hook_form_validate().
 */
// coin-flipping logic and session handling
function tao_iching_form_validate($form, &$form_state) {

  global $hexagram;

// define the 8 trigrams as arrays
   $kun = array(0, 0, 0); 
   $gen = array(1, 0, 0); 
   $kan = array(0, 1, 0); 
   $xun = array(1, 1, 0); 
   $zhen = array(0, 0, 1); 
   $li = array(1, 0, 1); 
   $dui = array(0, 1, 1); 
   $qian = array(1, 1, 1); 

   $toss = array();

// grab the question
   if ($form_state['values']['question']) {
	$_SESSION['question'] = $form_state['values']['question'];
   }
 
  if (isset($_POST['op'])) {

// toss three coins, get the result (heads = 1, tails = 0)
    for ($k = 0 ; $k < 3; $k++) {
      $toss[] = rand(0, 1);
    }

// logic for the coin toss

  if ($toss === $qian) {
	$val = 9;
	$line = "yang_changing";
  }

  if ($toss === $kun) {
	$val = 6;
	$line = "yin_changing";
  }

$sumtest = array_sum($toss);

  if ($sumtest == 2) {
	$val = 8;
	$line = "yin"; 
  }

  if ($sumtest == 1) {
	$val = 7;
	$line = "yang";
  }

// create a hexagram in $_SESSION

   $_SESSION['hexagram'][] = $line;
   $_SESSION['coinsval'] = $val;
   $arraysize = count($_SESSION['hexagram']);

   $val = NULL;

// once we have tossed the coins 6 times...
    if ($arraysize == 6) {

// check for changing lines
     $_SESSION['changed'] = $_SESSION['hexagram'];

      foreach($_SESSION['changed'] as $key => $value) {
  
	if ($value == "yang_changing") {
	  $_SESSION['changed'][$key] = "yin";
	} else if ($value == "yin_changing") {
	  $_SESSION['changed'][$key] = "yang";
	}

      } // end foreach()

	if ($_SESSION['changed'] === $_SESSION['hexagram']) {
	  $_SESSION['changed'] = NULL;
	  $_SESSION['changed'] = "No Change";
	}

  
	$hexagram = $_SESSION['hexagram'];
	$_SESSION['final_hexagram'] = $_SESSION['hexagram'];
	$_SESSION['final_changed'] = $_SESSION['changed'];

// flip the final arrays to display correctly (bottom to top)
	$_SESSION['final_hexagram'] = array_reverse($_SESSION['final_hexagram']);
    	if ($_SESSION['final_changed'] != "No Change") {
 	  $_SESSION['final_changed'] = array_reverse($_SESSION['final_changed']);
	}

     $_SESSION['hexagram'] = NULL;
     $_SESSION['changed'] = NULL;

    } // end if()

  } // end the submit function test

} // end of tao_iching_form_validate()


/**
 * Implements hook_form_submit().
 */
// submit redirects to the result page after more session sanitation
function tao_iching_form_submit($form, &$form_state) {

   global $hexagram;
    if ($hexagram != NULL) {
	$_SESSION['final_question'] = $_SESSION['question'];
	$_SESSION['question'] = NULL;
	$form_state['redirect'] = url('result');
	}
} // end of tao_iching_form_submit()



// makes the page output for the result page
function tao_iching_view() {

 include drupal_get_path('module', 'tao_iching') . "/includes/books.php";

// dont let the user land on this page first
  $path = $GLOBALS['base_url'];

   if (!array_key_exists('final_hexagram', $_SESSION)) {
	header("Location:" . $path . "/i-ching");
	die();
   } 

$content = "<div class='iching_content'>";
   $content .= "<div class='sm_hexag'>";

     foreach ($_SESSION['final_hexagram'] as $imgname) {

     $content .=  "<div class='min_line'>";
