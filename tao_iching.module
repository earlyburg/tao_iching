/**
 * tao_iching_submit_callback()
 *
 * AJAX callback builds the hexagrams and handles $_SESSION
 */
function tao_iching_submit_callback($form, $form_state) {

	$element = $form['iching_box'];
	$_SESSION['question'] = $form['question']['#value'];

	ctools_include('ajax');
	ctools_add_js('ajax-responder');
	$commands[] = ctools_ajax_command_redirect('result');

	// generate hexagram line
	$user_click = tao_iching_generate();

	// build the hexagram in _SESSION
	$_SESSION['hexagram'][] = $user_click['line'];
	$_SESSION['coinsval'] = $user_click['coinsval'];


	// once we have cast the coins 6 times...
	if ( count( $_SESSION['hexagram'] ) == 6 ) {

		// check for changing lines
		$_SESSION['changed'] = $_SESSION['hexagram'];

		foreach($_SESSION['changed'] as $key => $value) {
			// clean the output
			if ($value == "yang_changing") {
				$_SESSION['changed'][$key] = "yin";
			} else if ($value == "yin_changing") {
				$_SESSION['changed'][$key] = "yang";
			}

		} // end foreach()

		if ($_SESSION['changed'] === $_SESSION['hexagram']) {
			$_SESSION['changed'] = NULL;
			$_SESSION['changed'] = "No Change";
		}

		// clear and set the final hexagrams
		$_SESSION['final_hexagram'] = NULL;
		$_SESSION['final_changed'] = NULL;
		$_SESSION['final_hexagram'] = $_SESSION['hexagram'];
		$_SESSION['final_changed'] = $_SESSION['changed'];
		$_SESSION['final_question'] = $_SESSION['question'];

		// flip the final arrays to display correctly (bottom to top)
		$_SESSION['final_hexagram'] = array_reverse($_SESSION['final_hexagram']);
		if ($_SESSION['final_changed'] != "No Change") {
			$_SESSION['final_changed'] = array_reverse($_SESSION['final_changed']);
		}

		// clean up
		$_SESSION['hexagram'] = NULL;
		$_SESSION['changed'] = NULL;
		$_SESSION['question'] = NULL;
		$_SESSION['coinsval'] = 0;
		$user_click = NULL;

		print ajax_render($commands);
		exit;
	} // END the six flips check

	// create the coins display
	$arraysize = count( $_SESSION['hexagram']);
	$s = count( $_SESSION['hexagram']) - 1;

	if ( $arraysize != 0 ) {

    		$element['#markup'] = "<div class='iching_coindiv'>";

		switch ($_SESSION['coinsval']) {
			case 9:
				$element['#markup'] .= "<img src='/sites/all/modules/tao_iching/imgs/heads.png'>";
				$element['#markup'] .= "<img src='/sites/all/modules/tao_iching/imgs/heads.png'>";
				$element['#markup'] .= "<img src='/sites/all/modules/tao_iching/imgs/heads.png'>";
			       	break;
			case 8:
				$element['#markup'] .= "<img src='/sites/all/modules/tao_iching/imgs/heads.png'>";
				$element['#markup'] .= "<img src='/sites/all/modules/tao_iching/imgs/heads.png'>";
				$element['#markup'] .= "<img src='/sites/all/modules/tao_iching/imgs/tails.png'>";
			        break;
			case 7:
				$element['#markup'] .= "<img src='/sites/all/modules/tao_iching/imgs/heads.png'>";
				$element['#markup'] .= "<img src='/sites/all/modules/tao_iching/imgs/tails.png'>";
				$element['#markup'] .= "<img src='/sites/all/modules/tao_iching/imgs/tails.png'>";
			       	break;
			case 6;
				$element['#markup'] .= "<img src='/sites/all/modules/tao_iching/imgs/tails.png'>";
    				$element['#markup'] .= "<img src='/sites/all/modules/tao_iching/imgs/tails.png'>";
    				$element['#markup'] .= "<img src='/sites/all/modules/tao_iching/imgs/tails.png'>";
				break;
			case 0;
				$element['#markup'] .= "<img src='/sites/all/modules/tao_iching/imgs/heads.png'>";
			 	$element['#markup'] .= "<img src='/sites/all/modules/tao_iching/imgs/heads.png'>";
			 	$element['#markup'] .= "<img src='/sites/all/modules/tao_iching/imgs/heads.png'>";
				break;
			default:
				$element['#markup'] .= "<img src='/sites/all/modules/tao_iching/imgs/heads.png'>";
			 	$element['#markup'] .= "<img src='/sites/all/modules/tao_iching/imgs/heads.png'>";
			 	$element['#markup'] .= "<img src='/sites/all/modules/tao_iching/imgs/heads.png'>";
		}

		$element['#markup'] .= "</div>"; // .iching_coindiv

		// fix our output to be readable
    		$raw = $_SESSION['hexagram'][$s];

    		if ($raw == "yang_changing") {
			$legible = str_replace("yang_changing", "Yang, changing.", $raw);
    		}

    		if ($raw == "yin") {
			$legible = str_replace("yin", "Yin.", $raw);
    		}

    		if ($raw == "yin_changing") {
			$legible = str_replace("yin_changing", "Yin, changing.", $raw);
    		}

    		if ($raw == "yang") {
			$legible = str_replace("yang", "Yang.", $raw);
    		}

    		$element['#markup'] .= "<div class='iching_blurb'>";
    		$element['#markup'] .= "Coin toss " . $arraysize . " yields " . $legible;
    		$element['#markup'] .= "</div>"; // .iching_blurb

    		$element['#markup'] .= "<div class='sm_line'>";
    		$element['#markup'] .= "<img src='/sites/all/modules/tao_iching/imgs/" . $_SESSION['hexagram'][$s] . "_sm.png'>";
    		$element['#markup'] .= "</div>"; // sm_line

	} // end the array size if else()

	return $element;
}


/**
 * Implements hook_form().
 *
 * make the form
 */
function tao_iching_form($form, &$form_state) {

	$form['question'] = array(
   		'#type' => 'textarea',
   		'#title' => 'Ask A Question.',
   		'#cols' => 10,
   		'#resizable' => FALSE,
   		'#rows' => 1,
   	);

  	$form['iching_box'] = array(
   	 	'#type' => 'markup',
    		'#prefix' => '<div id="iching_box">',
    		'#suffix' => '</div>',
    		'#markup' => '<h3>Please click to toss the coins.</h3>',
  	);

  	$form['submit_button'] = array(
    		'#type' => 'submit',
    		'#ajax' => array(
      			'callback' => 'tao_iching_submit_callback',
      			'wrapper' => 'iching_box',
    		),
    		'#value' => t('Toss The Coins'),
		'#attributes' => array(
			'class' => array(
				'i-ching-submit'),
			'name' => array(
				'i-ching-toss',
			),
		),
  	);

  	return $form;

}


/**
 * tao_iching_generate().
 *
 * generates i-ching lines
 */
function tao_iching_generate() {

	$toss = array();
	$return_vals = array();

	// define the 8 trigrams as arrays
	$kun = array(0, 0, 0);
	$gen = array(1, 0, 0);
	$kan = array(0, 1, 0);
	$xun = array(1, 1, 0);
	$zhen = array(0, 0, 1);
	$li = array(1, 0, 1);
	$dui = array(0, 1, 1);
	$qian = array(1, 1, 1);

	// toss three coins, get the result (heads = 1, tails = 0)
	for ($k = 0 ; $k < 3; $k++) {
		$toss[] = rand(0, 1);
	}

	// logic for the coin toss

	if ($toss === $qian) {
		$val = 9;
		$line = "yang_changing";
	}

	if ($toss === $kun) {
		$val = 6;
		$line = "yin_changing";
	}

	$sumtest = array_sum($toss);

	if ($sumtest == 2) {
		$val = 8;
		$line = "yin";
	}

	if ($sumtest == 1) {
		$val = 7;
		$line = "yang";
	}


	$return_vals['line'] = $line;
	$return_vals['coinsval'] = $val;

	return $return_vals;
}


/**
 * Implements hook_view().
 *
 * makes the page output for the result page
 */
function tao_iching_view() {

	include drupal_get_path('module', 'tao_iching') . "/includes/books.php";

	// dont let the user land on this page first
  	$path = $GLOBALS['base_url'];

   	if (!array_key_exists('final_hexagram', $_SESSION)) {
		header("Location:" . $path . "/i-ching");
		die();
   	}

	$content = "<div class='iching_content'>";
   	$content .= "<div class='sm_hexag'>";

     	foreach ($_SESSION['final_hexagram'] as $imgname) {

     		$content .=  "<div class='min_line'>";
     		$content .=  "<img src='/sites/all/modules/tao_iching/imgs/" . $imgname . "_min.png'>";
     		$content .=  "</div>";
    	}

   	$content .= "</div>";

   	$content .= "<div class='sm_hexag'>";

     	if ($_SESSION['final_changed'] == "No Change") {

      		$content .=  "<div class='sm_iching_blurb'>";
      		$content .=  "No changing lines. The situation is expected to remain the same.";
      		$content .=  "</div>";
     	}

     	if (($_SESSION['final_changed'] != NULL) && ($_SESSION['final_changed'] != "No Change")) {

      		foreach ($_SESSION['final_changed'] as $chgname) {

       			$content .=  "<div class='min_line'>";
       			$content .=  "<img src='/sites/all/modules/tao_iching/imgs/" . $chgname . "_min.png'>";
       			$content .=  "</div>";
      		}
     	} // end if

   	$content .= "</div>";

  	$content .= "<div class='iching_blurb'>";
  	$content .= "<a href='i-ching'><b>Click Here to start again.</b></a>";
  	$content .= "</div>";
  	$content .= "</div>";

	//    dpm($_SESSION, $name=NULL);
	// include drupal_get_path('module', 'tao_iching') . "/includes/result_html.php";

 	$content .= "<div class='iching_container'>";


  	$rawhex = $_SESSION['final_hexagram'];
  	$finalchg = $_SESSION['final_changed'];

	// get rid of the change indicators and display the final hexagram(s)
  	$finalhex = tao_iching_rawhex_cleanup($_SESSION['final_hexagram']);

	// get the book numbers for the hexagram(s)
  	$bookname = tao_iching_booklookup(array_reverse($finalhex));

  	if($finalchg != "No Change") {
   		$ch_bookname = tao_iching_booklookup(array_reverse($finalchg));
  	}


	// print the question

	if ($_SESSION['final_question'] != NULL) {
     		$content .= "<div class='iching_blurb'>";
       		$content .= "<b>";
       		$content .= $_SESSION['final_question'];
       		$content .= "</b>";
       		$content .= "</div>";
     	}
     	$content .= "<div class='iching_blurb'>";
     	$content .= "<br>";
     	$content .= "</div>";

  	$content .= "<div class='iching_tab'>";
	// bring in html to make our javascript work
  	$content .= file_get_contents(drupal_get_path('module', 'tao_iching') . "/includes/result_html.php");

  	$content .= "</div>";

  	$content .= "<div id='Current' class='iching_tabcontent'>";
  	$content .= "<h3>Current</h3>";

     	$content .= "<div class='hexag'>";
      	foreach ($finalhex as $hexname) {
       		$content .= "<div class='sm_line'>";
       		$content .= "<img src='/sites/all/modules/tao_iching/imgs/" . $hexname . "_sm.png'>";
       		$content .= "</div>";
      	}
     	$content .= "</div>";


   	$content .= "<div class='iching_links'>";

   	$content .= "<a class='colorbox-inline' href='?width=600&height=500&inline=true#iching_j_text'>The Judgement</a>";
   	$content .= "<div style='display: none;'>";
   	$content .= "<div id='iching_j_text'><p>" . $book[$bookname]['judge'] . "</p></div>";
   	$content .= "</div>";

   	$content .= "<a class='colorbox-inline' href='?width=600&height=500&inline=true#iching_i_text'>The Image</a>";
   	$content .= "<div style='display: none;'>";
   	$content .= "<div id='iching_i_text'><p>" . $book[$bookname]['image'] . "</p></div>";
   	$content .= "</div>";

   	$content .= "</div>";


   	$content .= $bookname . " - ";
   	$content .= $book[$bookname]['desc'];


  	$content .= "</div>";

  	$content .= "<div id='Changing' class='iching_tabcontent'>";
  	$content .= "<h3>Changing</h3>";


    	if($finalchg != "No Change") {
     		$content .= "<div class='hexag'>";
		$book_cng_key = tao_iching_find_top_changing($rawhex);
         	foreach ($rawhex as $rawname) {
          		$content .= "<div class='sm_line'>";
          		$content .= "<img src='/sites/all/modules/tao_iching/imgs/" . $rawname . "_sm.png'>";
          		$content .= "</div>";
         	}
     		$content .= "</div>";
    	} else $content .= "<div>There are no changing lines. The situation is expected to remain the same in the near future.</div>";

      	if($finalchg != "No Change") {
       		$content .= $book[$ch_bookname][$book_cng_key];
	}


	$content .= "</div>";

	$content .= "<div id='Transformed' class='iching_tabcontent'>";
 	$content .= "<h3>Transformed</h3>";

    	if($finalchg != "No Change") {
     		$content .= "<div class='hexag'>";
       		foreach ($finalchg as $chgname) {
        		$content .= "<div class='sm_line'>";
        		$content .= "<img src='/sites/all/modules/tao_iching/imgs/" . $chgname . "_sm.png'>";
        		$content .= "</div>";
       		}
      		$content .= "</div>";
     	} else $content .= "<div>There are no changing lines. The situation is expected to remain the same in the near future.</div>";


      	if($finalchg != "No Change") {
		$content .= "<div class='iching_links'>";

		$content .= "<a class='colorbox-inline' href='?width=600&height=500&inline=true#iching_j_ch_text'>The Judgement</a>";
		$content .= "<div style='display: none;'>";
		$content .= "<div id='iching_j_ch_text'><p>" . $book[$ch_bookname]['judge'] . "</p></div>";
		$content .= "</div>";
		$content .= "<a class='colorbox-inline' href='?width=600&height=500&inline=true#iching_i_ch_text'>The Image</a>";
		$content .= "<div style='display: none;'>";
		$content .= "<div id='iching_i_ch_text'><p>" . $book[$ch_bookname]['image'] . "</p></div>";
		$content .= "</div>";

   		$content .= "</div>";

	}

   	if($finalchg != "No Change") {
    		$content .= $ch_bookname . " - ";
    		$content .= $book[$ch_bookname]['desc'];
   	}

  	$content .= "</div>";
  	$content .= "</div>";

  	$content .= "<SCRIPT>";
	// Get the element with id="defaultOpen" and click on it

  	$content .= "document.getElementById('defaultOpen').click();";
  	$content .= "</SCRIPT>";

 	return $content;

   	$_SESSION['final_hexagram'] = NULL;
   	$_SESSION['final_changed'] = NULL;
   	$_SESSION['final_question'] = NULL;

 }


/**
 * tao_iching_booklookup($hex)
 *
 * returns the book name from the database when passed a hexagram array
 */
function tao_iching_booklookup($hex) {

	$bookname = db_query('SELECT book_number FROM {hexagrams} WHERE line1 = :line1 AND line2 = :line2 AND line3 = :line3 AND line4 = :line4 AND line5 = :line5 AND line6 = :line6', array(
  		':line1' => $hex[0],
  		':line2' => $hex[1],
  		':line3' => $hex[2],
  		':line4' => $hex[3],
  		':line5' => $hex[4],
  		':line6' => $hex[5],
		))->fetchField();

	return $bookname;

}


/**
 * tao_iching_find_top_changing($rawhex)
 *
 * takes a 'raw' hexagram and returns the number of the top changing line
 */
function tao_iching_find_top_changing($rawhex) {

   	$yin_keys = array_keys($rawhex, "yin_changing");
   	$yang_keys = array_keys($rawhex, "yang_changing");

   	$integrated = array_merge($yin_keys, $yang_keys);
   	sort($integrated, SORT_NUMERIC);

   	$top_changed = $integrated[0];
    	switch ($top_changed) {
     		case "0":
        		$line_pos = "6";
        		break;
     		case "1":
        		$line_pos = "5";
        		break;
     		case "2":
        		$line_pos = "4";
        		break;
     		case "3":
        		$line_pos = "3";
        		break;
     		case "4":
        		$line_pos = "2";
        		break;
     		case "5":
        		$line_pos = "1";
        		break;
  	}

   	$topchanging = "line" . $line_pos;

   	return $topchanging;

}


/**
 * tao_iching_rawhex_cleanup($raw)
 *
 * takes a 'raw' hexagram array and removes the "_changing" part from any value if present
 */
function tao_iching_rawhex_cleanup($raw) {

   	for($i=0;$i<count($raw);$i++) {

		switch ($raw[$i]) {
     			case "yang_changing":
        			$raw[$i] = "yang";
        			break;
     			case "yin_changing":
        			$raw[$i] = "yin";
        			break;
		}
  	}
   	$cleaned = $raw;
   	return $cleaned;

}


